# ==============================================
# APP CONFIGURATION
# ==============================================
APP_NAME=Agent Service
VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ==============================================
# LLM PROVIDER CONFIGURATION
# ==============================================
DEFAULT_LLM_PROVIDER=gemini

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5-nano

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-4-5-20250929

# Google Gemini Configuration
GEMINI_API_KEY=AIzaSyB_VaZGn_nI7WhgZ8TM6bea2U5vsjZr9nM
GOOGLE_API_KEY=AIzaSyB_VaZGn_nI7WhgZ8TM6bea2U5vsjZr9nM
GEMINI_MODEL=gemini-2.5-pro

# Ollama Configuration (for local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ==============================================
# DATABASE CONFIGURATION (PostgreSQL + PGVector)
# ==============================================
# Main Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chatbot_chat_db

# Database URL for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
SQLAGENT_DATABASE_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
POSTGRES_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO_SQL=false

# ==============================================
# PGVECTOR CONFIGURATION
# ==============================================
# Vector dimension for embeddings (OpenAI ada-002 = 1536, Gemini = 768)
VECTOR_DIMENSION=768
EMBEDDING_MODEL=models/text-embedding-004

# ==============================================
# LANGGRAPH CONFIGURATION
# ==============================================
# Supervisor Agent Settings
MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60

# ==============================================
# TOOLS CONFIGURATION
# ==============================================
# SQL Generator Settings
SQL_GENERATION_MAX_RETRIES=3
SQL_VALIDATION_ENABLED=true

# Query Executor Settings
QUERY_TIMEOUT_SECONDS=30
MAX_QUERY_RESULTS=1000

# ==============================================
# AGENT-SPECIFIC SETTINGS
# ==============================================
# Product Agent
PRODUCT_AGENT_MODEL=gemini-2.5-pro
PRODUCT_AGENT_TEMPERATURE=0.3

# Sales Agent
SALES_AGENT_MODEL=gemini-2.5-pro
SALES_AGENT_TEMPERATURE=0.3

# Stock Agent
STOCK_AGENT_MODEL=gemini-2.5-pro
STOCK_AGENT_TEMPERATURE=0.3

# Store Agent
STORE_AGENT_MODEL=gemini-2.5-pro
STORE_AGENT_TEMPERATURE=0.3

# Customer Agent
CUSTOMER_AGENT_MODEL=gemini-2.5-pro
CUSTOMER_AGENT_TEMPERATURE=0.3

# Report Agent
REPORT_AGENT_MODEL=gemini-2.5-pro
REPORT_AGENT_TEMPERATURE=0.5

# ==============================================
# REDIS CONFIGURATION (untuk caching nanti)
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=3600

# ==============================================
# API SECURITY (untuk nanti kalau sudah ada API Gateway)
# ==============================================
# Internal API Key untuk komunikasi antar service
INTERNAL_API_KEY=your-internal-api-key-here

# ==============================================
# MONITORING & OBSERVABILITY (optional)
# ==============================================
# Sentry untuk error tracking
SENTRY_DSN=

# Prometheus metrics
ENABLE_METRICS=false
METRICS_PORT=9090